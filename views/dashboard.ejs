<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <!-- Navbar -->

    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a href="#" class="navbar-brand">Course Management</a>

            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>
    </nav>

    <!-- Welcome -->

    <div class="container mt-5">

        <div class="card p-4">

            <h2>Welcome <%= Fname %></h2>

            <p>
                You have successfully logged in.
            </p>

            <hr>

            <div class="row">

                <div class="col-md-4">

                    <div class="card p-3">

                        <h4>Add Course</h4>

                        <p>Add a new course.</p>

                        <a href="/addCourse" class="btn btn-primary">
                            Add Course
                        </a>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="card p-3">

                        <h4>View Courses</h4>

                        <p>Display all courses.</p>

                       <a href="/displayCourse" class="btn btn-success">
                             View Courses
                            </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>
</html>